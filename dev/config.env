# Ozma dev harness — shared config
# Source this in scripts: . "$(dirname "$0")/../config.env"

# QEMU image paths — resolved by each launch script relative to its IMAGES_DIR.
# Override with env vars if needed: RISCV_IMAGE=/path/to/riscv-node.qcow2 make node-vm

# RISC-V node VM
NODE_SSH_PORT=2222
NODE_HID_PORT=7331       # UDP
NODE_STREAM_PORT=7382    # TCP (HLS)
NODE_USBIP_PORT=3240     # TCP (USB/IP)

# Target VM (the machine being KVM'd)
TARGET_SSH_PORT=2223
TARGET_VNC_PORT=5900

# Controller (runs on host)
CONTROLLER_PORT=7380

# VM resources
NODE_VCPUS=4
NODE_MEM=2G
TARGET_VCPUS=2
TARGET_MEM=1G

# SSH key (generated by: make ssh-key)
SSH_KEY="${SSH_KEY:-$(dirname "$0")/../images/dev_key}"
SSH_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR"

# RISC-V VM login (Ubuntu cloud image default is ubuntu/ubuntu or key-only)
NODE_USER=ubuntu
TARGET_USER=root

# Network mode: 'slirp' (no root needed) or 'tap' (needs root, enables mDNS)
NETWORK_MODE="${NETWORK_MODE:-slirp}"
TAP_IFACE="${TAP_IFACE:-ozma-tap0}"
TAP_HOST_IP="192.168.100.1"
TAP_VM_IP="192.168.100.10"
