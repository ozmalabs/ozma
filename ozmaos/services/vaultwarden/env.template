# Vaultwarden Environment Template

# Public URL (required for notifications, WebAuthn)
DOMAIN=http://localhost:8222

# Registration (set to true to allow new users)
SIGNUPS_ALLOWED=false

# Admin panel token (generate with: openssl rand -base64 48)
ADMIN_TOKEN=your_admin_token_here

# SMTP Configuration (optional, for email notifications)
SMTP_HOST=smtp.example.com
SMTP_FROM=no-reply@example.com
SMTP_PORT=587
SMTP_SSL=true
SMTP_USERNAME=
SMTP_PASSWORD=

# YubiKey OTP (optional)
YUBICO_CLIENT_ID=
YUBICO_SECRET_KEY=

# Security options
SHOW_PASSWORD_HINT=false
EMERGENCY_ACCESS_ALLOWED=false
