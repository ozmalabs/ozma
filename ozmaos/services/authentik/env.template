# Authentik Environment Template

# Version (check https://github.com/goauthentik/authentik/releases)
AUTHENTIK_VERSION=2024.10.2

# Secret key (generate with: openssl rand -base64 48)
AUTHENTIK_SECRET_KEY=your_secret_key_here

# Log level (debug, info, warning, error)
AUTHENTIK_LOG_LEVEL=info

# PostgreSQL
POSTGRES_USER=authentik
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=authentik

# Redis (no password by default)
# REDIS_PASSWORD=
